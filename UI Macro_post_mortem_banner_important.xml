<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

    <style>
        .pm-banner-container2 {
            background-color: #c73030;
            border-left: 5px solid #27348b;
            padding: 12px 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: flex-start;
            border-radius: 3px;
        }

        .pm-banner-icon2 {
            font-size: 2.5em;
			      margin-top: 0;
			      position: relative;
			      top: -5px;
            margin-right: 15px;
